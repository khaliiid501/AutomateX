# .env.example – Copy this file to .env and fill in your values.
# Do NOT commit your actual .env file to version control.

# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Sender email credentials
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_email_password

# Application environment: "development" (print fallback) or "production" (real SMTP)
APP_ENV=development

# Path to the JSON file that contains tasks (optional, defaults to data/tasks.json)
# TASKS_FILE=/absolute/path/to/tasks.json
